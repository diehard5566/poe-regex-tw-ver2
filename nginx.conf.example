# Nginx 配置範例
# 將此檔案複製到 /etc/nginx/sites-available/regex.poepricer.com
# 然後建立 symbolic link: sudo ln -s /etc/nginx/sites-available/regex.poepricer.com /etc/nginx/sites-enabled/
# 測試配置: sudo nginx -t
# 重新載入: sudo systemctl reload nginx

# 如果使用 Cloudflare Flexible SSL 模式（Cloudflare <-> 伺服器用 HTTP）
server {
	listen 80;
	server_name regex.poepricer.com;

	# 前端靜態檔案
	root /path/to/poe-regex-tw/client/build;
	index index.html;

	# Gzip 壓縮
	gzip on;
	gzip_vary on;
	gzip_min_length 1024;
	gzip_types text/plain text/css text/xml text/javascript application/x-javascript application/xml+rss application/json application/javascript;

	# API 反向代理
	location /api/v1/ {
		proxy_pass http://localhost:9000/;
		proxy_http_version 1.1;
		proxy_set_header Upgrade $http_upgrade;
		proxy_set_header Connection 'upgrade';
		proxy_set_header Host $host;
		proxy_set_header X-Real-IP $remote_addr;
		proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
		proxy_set_header X-Forwarded-Proto $scheme;
		proxy_cache_bypass $http_upgrade;
		proxy_read_timeout 300s;
		proxy_connect_timeout 75s;
	}

	# React Router - 所有其他路徑都回傳 index.html
	location / {
		try_files $uri $uri/ /index.html;
	}

	# 靜態資源快取
	location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
		expires 1y;
		add_header Cache-Control "public, immutable";
	}
}

# 如果使用 Cloudflare Full/Full Strict SSL 模式（需要 Let's Encrypt 證書）
# 取消註解以下區塊，並註解掉上面的 server 區塊
# 需要先安裝 certbot: sudo apt install certbot python3-certbot-nginx
# 然後執行: sudo certbot --nginx -d regex.poepricer.com

