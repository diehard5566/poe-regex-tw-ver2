{
	"version": 2,
	"buildCommand": "cd client && npm install && npm run build",
	"outputDirectory": "client/build",
	"builds": [
		{
			"src": "api/index.js",
			"use": "@vercel/node"
		}
	],
	"rewrites": [
		{
			"source": "/api/v1/(.*)",
			"destination": "/api/index.js"
		},
		{
			"source": "/(.*)",
			"destination": "/index.html"
		}
	]
}
