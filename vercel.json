{
	"version": 2,
	"builds": [
		{
			"src": "api/index.js",
			"use": "@vercel/node"
		},
		{
			"src": "client/package.json",
			"use": "@vercel/static-build",
			"config": {
				"distDir": "build"
			}
		}
	],
	"routes": [
		{
			"src": "/api/v1/:path*",
			"dest": "api/index.js"
		},
		{
			"src": "/:path*",
			"dest": "client/build/:path*"
		}
	],
	"functions": {
		"api/**/*.js": {
			"runtime": "nodejs22.x"
		}
	}
}
