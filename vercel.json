{
	"version": 2,
	"buildCommand": "cd client && npm install && npm run build && cd ../api && npm install",
	"outputDirectory": "client/build",
	"functions": {
		"api/index.js": {
			"includeFiles": "server/**",
			"memory": 1024,
			"maxDuration": 10
		}
	},
	"rewrites": [
		{
			"source": "/api/v1/(.*)",
			"destination": "/api/index.js"
		},
		{
			"source": "/(.*)",
			"destination": "/index.html"
		}
	]
}
