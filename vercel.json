{
	"version": 2,
	"builds": [
		{
			"src": "api/index.js",
			"use": "@vercel/node@3.0.7"
		},
		{
			"src": "client/package.json",
			"use": "@vercel/static-build@3.0.0",
			"config": {
				"distDir": "build"
			}
		}
	],
	"routes": [
		{
			"src": "/api/v1/(.*)",
			"dest": "api/index.js"
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "/(.*)",
			"dest": "client/build/index.html"
		}
	],
	"functions": {
		"api/**/*.js": {
			"runtime": "nodejs22.x"
		}
	}
}
